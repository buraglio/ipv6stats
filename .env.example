# IPv6 Statistics Dashboard - Environment Variables
# Copy this file to .env and fill in your API keys

# Cloudflare Radar API Token (optional but recommended)
# Get your free token at: https://dash.cloudflare.com/profile/api-tokens
# Use the "Read Analytics" template or create a custom token with Zone:Analytics:Read permissions
# Without this token, the dashboard uses estimated data (~36% IPv6)
CLOUDFLARE_API_KEY=your_cloudflare_api_token_here

# Future API keys can be added here
# AWS_ACCESS_KEY_ID=your_aws_key
# AZURE_SUBSCRIPTION_ID=your_azure_id
