# IPv6 Statistics Dashboard - Environment Variables
# Copy this file to .env and fill in your API keys
#
# All keys are optional. The dashboard degrades gracefully when keys are absent,
# displaying labeled research estimates in place of live data and showing a
# warning banner so users know the data source.

# ── Cloudflare Radar (strongly recommended) ─────────────────────────────────
# Used by: per-country IPv6 adoption, DNS resolver stats, Facebook/Meta traffic
# Without it: ~4 data sources fall back to 2024-2025 research estimates.
#
# Create a token at: https://dash.cloudflare.com/profile/api-tokens
# Required permission scope: Radar > Read  (a.k.a. "cloudflare_radar:read")
# The "Read Analytics and Logs" template does NOT include Radar scope —
# use "Create Custom Token" and add Account > Cloudflare Radar > Read.
CLOUDFLARE_API_KEY=your_cloudflare_api_token_here

# ── RIPE Atlas ───────────────────────────────────────────────────────────────
# Used by: RIPE Atlas measurement data (read access is currently open/unauthenticated)
# An API key is only required for write operations (scheduling new measurements).
# Leave blank unless you need to trigger custom measurements.
#
# Create at: https://atlas.ripe.net/keys/
RIPE_ATLAS_API_KEY=

# ── PeeringDB ────────────────────────────────────────────────────────────────
# Used by: network operator IPv6 self-reported adoption (PeeringDB API)
# Read access is currently open (no auth required for the /net endpoint).
# An API key gives higher rate limits and access to non-public records.
#
# Create at: https://www.peeringdb.com/account/auth/token/
PEERINGDB_API_KEY=

# ── Routeviews ───────────────────────────────────────────────────────────────
# Used by: per-carrier BGP prefix visibility, per-RIR IPv6 peer counts
# Guest access is currently sufficient (1 req/sec rate limit applies).
# A registered API key would increase the rate limit for high-frequency use.
#
# Request access at: https://www.routeviews.org/routeviews/index.php/community/contact/
ROUTEVIEWS_API_KEY=

# ── AWS / Azure (not currently used) ─────────────────────────────────────────
# AWS and Azure IPv6 coverage is derived from their public IP-ranges JSON files
# (no auth required). These keys are placeholders for future enrichment.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AZURE_SUBSCRIPTION_ID=
